
# Override global ~/.config/git/ignore which excludes `build` dirs. macpi
# uses build/ for the app icon source + generated platform artifacts. The
# iconset/ subdir is an intermediate created by scripts/build-icons.sh.
!build/
!build/**
build/icon.iconset/

.cache
.claude/
.claire/
.DS_Store
.dynamodb/
.env
.env.test
.eslintcache
.fusebox/
.lock-wscript
.next
.node_repl_history
.npm
.nuxt
.nyc_output
.serverless/
.superpowers/
.vite/
.vuepress/dist
.webpack/
.yarn-integrity
*.lcov
*.log
*.pid
*.pid.lock
*.seed
*.tgz
*.tsbuildinfo
